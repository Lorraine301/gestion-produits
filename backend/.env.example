# Port sur lequel le serveur Express va écouter
PORT=5000

# Chaîne de connexion MongoDB Atlas
# Remplacez <username>, <password> et <cluster-url> par vos propres informations Atlas
# Exemple : mongodb+srv://monUser:monMotDePasse@cluster0.xxxxx.mongodb.net/gestion-produits?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/gestion-produits?retryWrites=true&w=majority

# URL du frontend autorisée pour les requêtes CORS
CLIENT_URL=http://localhost:4200
